# Backend server
PORT=5000
NODE_ENV=development

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE=7d

# Supabase (required for rooms/auth persistence)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional fallback (less privilege). Prefer SERVICE_ROLE in backend.
# SUPABASE_ANON_KEY=your-anon-key

# Optional table names (defaults shown)
AUTH_USERS_TABLE=users
COLLAB_ROOMS_TABLE=rooms
COLLAB_ROOM_MEMBERS_TABLE=roommembers
COLLAB_ROOM_FILES_TABLE=roomfiles
COLLAB_EDIT_SNAPSHOTS_TABLE=editsnapshots

# Optional: only used for explicit health-table checks
# SUPABASE_HEALTH_TABLE=rooms

# Optional AI configuration
# OPENAI_API_KEY=your-openai-key
# OPENAI_MODEL=gpt-4.1-mini
